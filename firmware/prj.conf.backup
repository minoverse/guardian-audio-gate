CONFIG_PRINTK=y
CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_CMSIS_DSP=y
CONFIG_FPU=y

# Enable CMSIS-DSP Filtering module
CONFIG_CMSIS_DSP_FILTERING=y

CONFIG_DEBUG=y

# Timing measurement
CONFIG_TIMING_FUNCTIONS=y

# CMSIS-DSP Statistics (for arm_rms_q15)
CONFIG_CMSIS_DSP_STATISTICS=y



# I2S for microphone
CONFIG_BOOTLOADER_MCUBOOT=n



# nRFx PDM for microphone
CONFIG_NRFX_PDM=y

# Disable MPU to allow nrfx direct access
CONFIG_ARM_MPU=n

# Disable USB for Li-Po measurement
CONFIG_USB_DEVICE_STACK=n
CONFIG_UART_CONSOLE=n
CONFIG_CONSOLE=n
